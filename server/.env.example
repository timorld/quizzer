# Copy this file to ".env" (same directory) and fill in your real values.
# The .env file is gitignored — never commit it.

# Required for AI conversion
NVIDIA_API_KEY=

# Optional — defaults shown
NVIDIA_API_ENDPOINT=https://inference-api.nvidia.com/v1/chat/completions
NVIDIA_API_MODEL=openai/openai/gpt-5-mini
